[gd_resource type="Theme" load_steps=6 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/m6x11.ttf" id="1_font"]
[ext_resource type="FontFile" path="res://assets/fonts/NotoSansSC-Regular.otf" id="2_noto"]

[sub_resource type="SystemFont" id="SystemFont_cjk"]
; 系统中文字体回退 (桌面端用; ⚠ web 沙箱取不到系统字体 → 靠下面【打包的 Noto】兜底, 否则 web 中文乱码)
font_names = PackedStringArray("Microsoft YaHei", "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "WenQuanYi Micro Hei", "sans-serif")
allow_system_fallback = true

[sub_resource type="FontVariation" id="FontVariation_main"]
; m6x11 像素字体打底(英文/数字) → 缺的中文字形先回退【打包的 Noto SC】(web 也有字形=修乱码) → 再回退系统CJK(桌面美观)
base_font = ExtResource("1_font")
fallbacks = Array[Font]([ExtResource("2_noto"), SubResource("SystemFont_cjk")])

[sub_resource type="FontVariation" id="FontVariation_bold"]
; 合成粗体 (RichTextLabel [b] 用; 1:1 PoC 部分文字 font-weight 700-900)
base_font = SubResource("FontVariation_main")
variation_embolden = 0.6

[resource]
default_font = SubResource("FontVariation_main")
default_font_size = 16
; RichTextLabel 不像 Label 自动用 default_font, 显式给它配字体 → 全局富文本(图鉴/战斗日志/弹窗)统一 m6x11+Noto
RichTextLabel/fonts/normal_font = SubResource("FontVariation_main")
RichTextLabel/fonts/bold_font = SubResource("FontVariation_bold")
RichTextLabel/fonts/italics_font = SubResource("FontVariation_main")
RichTextLabel/fonts/bold_italics_font = SubResource("FontVariation_bold")
RichTextLabel/fonts/mono_font = SubResource("FontVariation_main")
